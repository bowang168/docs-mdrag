# Qdrant local database
.db/

# Fetched / user documents (re-creatable; may contain sensitive content)
docs/

# BM25 model and hash cache (auto-generated by ingest, live inside .db/)
# .db/ is already ignored above; these patterns also catch them if relocated.
.bm25.json
.hash_cache.json
**/.bm25.json
**/.hash_cache.json

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# Logs
*.log
